<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:paddingStart="16dp"
    android:paddingTop="6dp"
    android:paddingEnd="8dp"
    android:paddingBottom="6dp">

    <ImageView
        android:id="@+id/station_cover_image_view"
        android:layout_width="44dp"
        android:layout_height="44dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/station_name_text_view"
        style="@style/LabelMedium"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:ellipsize="end"
        android:singleLine="true"
        android:text="@string/label_placeholder"
        app:layout_constraintBottom_toTopOf="@id/station_details_text_view"
        app:layout_constraintEnd_toStartOf="@id/add_station_button"
        app:layout_constraintStart_toEndOf="@id/station_cover_image_view"
        app:layout_constraintTop_toTopOf="@id/station_cover_image_view"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/station_details_text_view"
        style="@style/LabelSmall"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:ellipsize="end"
        android:singleLine="true"
        android:text="@string/label_placeholder"
        app:layout_constraintBottom_toBottomOf="@id/station_cover_image_view"
        app:layout_constraintEnd_toStartOf="@id/add_station_button"
        app:layout_constraintStart_toEndOf="@id/station_cover_image_view"
        app:layout_constraintTop_toBottomOf="@id/station_name_text_view" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/add_station_button"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/radio_search_add"
        android:textAllCaps="false"
        android:textSize="12sp"
        android:minWidth="0dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
